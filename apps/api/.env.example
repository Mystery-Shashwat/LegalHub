# ── Database (from Neon.tech)
DATABASE_URL="postgresql://neondb_owner:[EMAIL_ADDRESS]:5432/neondb?sslmode=require&channel_binding=require"
# ── JWT (generate random 32+ char strings)
JWT_SECRET="your-super-secret-jwt-key-at-least-32-chars"
JWT_REFRESH_SECRET="another-secret-for-refresh-tokens-32-chars"

# ── App
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# ── Razorpay (from razorpay.com dashboard)
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"

# ── Cloudflare R2 (from CF dashboard → R2 → API tokens)
CF_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY="your-r2-access-key"
R2_SECRET_KEY="your-r2-secret-key"
R2_BUCKET="legalhub-docs"
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"

# ── Resend (from resend.com dashboard)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@legalhub.in"
